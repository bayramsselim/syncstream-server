{
  "manifest_version": 3,
  "name": "SyncStream Pro",
  "version": "1.1.0",
  "description": "Watch videos together, synced in real-time.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "incognito": "split",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "world": "MAIN",
      "run_at": "document_start",
      "js": ["content-main.js"]
    },
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content.js"]
    }
  ]
}
